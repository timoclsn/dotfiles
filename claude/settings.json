{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/hooks/notify.ts",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/hooks/notify.ts",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/hooks/format.ts"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun ~/.claude/hooks/statusline.ts"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "dev-toolkit@taxfix-plugins-marketplace": true,
    "vercel@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "xhigh",
  "promptSuggestionEnabled": false,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "terminalProgressBarEnabled": false,
  "skipAutoPermissionPrompt": true,
  "tipsEnabled": false
}
