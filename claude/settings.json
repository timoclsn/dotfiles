{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/hooks/notify.ts",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ~/.claude/hooks/notify.ts",
            "async": true
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "enableWorkflows": false,
  "statusLine": {
    "type": "command",
    "command": "bun ~/.claude/hooks/statusline.ts"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "dev-toolkit@taxfix-plugins-marketplace": false,
    "vercel@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "deployment-toolkit@taxfix-plugins-marketplace": true,
    "oncall@taxfix-plugins-marketplace": true
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "tui": "fullscreen",
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "preferredNotifChannel": "notifications_disabled",
  "terminalProgressBarEnabled": false,
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": false,
  "agentPushNotifEnabled": false,
  "skipAutoPermissionPrompt": true,
  "tipsEnabled": false,
  "workflowKeywordTriggerEnabled": false
}
